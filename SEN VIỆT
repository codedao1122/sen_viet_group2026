<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký Sen Việt Group - Rực Rỡ Mùa Hè</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Phông chữ Inter chuyên nghiệp -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Thư viện quét mã QR -->
    <script src="https://unpkg.com/html5-qrcode"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    
    <style>
        :root {
            --summer-green: #22c55e;
            --summer-orange: #fb923c;
            --light-green: #f0fdf4;
            --light-orange: #fff7ed;
        }

        body { 
            background: linear-gradient(135deg, var(--light-green) 0%, var(--light-orange) 100%); 
            font-family: 'Inter', sans-serif; 
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        /* Hiệu ứng mặt trời trang trí */
        .sun-decoration {
            position: fixed;
            top: -50px;
            right: -50px;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(251, 146, 60, 0.2) 0%, rgba(251, 146, 60, 0) 70%);
            border-radius: 50%;
            z-index: -1;
            animation: pulse-sun 4s infinite alternate;
        }

        @keyframes pulse-sun {
            from { transform: scale(1); opacity: 0.5; }
            to { transform: scale(1.2); opacity: 0.8; }
        }
        
        .summer-header {
            background: linear-gradient(135deg, #16a34a 0%, #fb923c 100%);
            position: relative;
            overflow: hidden;
        }

        .summer-header::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 20 20' xmlns='http://www.w3.org/2000%2Fsvg'%3E%3Cg fill='%23ffffff' fill-opacity='0.05' fill-rule='evenodd'%3E%3Ccircle cx='3' cy='3' r='3'/%3E%3Ccircle cx='13' cy='13' r='3'/%3E%3C/g%3E%3C/svg%3E");
        }

        .form-card { 
            background: rgba(255, 255, 255, 0.9); 
            backdrop-filter: blur(12px);
            border-radius: 24px; 
            border: 1px solid white;
            box-shadow: 0 25px 50px -12px rgba(22, 163, 74, 0.1);
        }

        .input-group { position: relative; }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--summer-orange);
            font-size: 0.9rem;
            transition: all 0.3s;
        }

        .styled-input {
            padding-left: 42px !important;
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            background-color: white;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

        .styled-input:focus {
            border-color: var(--summer-orange);
            box-shadow: 0 0 0 4px rgba(251, 146, 60, 0.15);
            outline: none;
        }
        
        .styled-input:focus + .input-icon {
            color: var(--summer-green);
        }

        .scanner-container { 
            border-radius: 20px; 
            border: 3px dashed var(--summer-green); 
            background: #0f172a; 
            min-height: 250px; 
            overflow: hidden;
        }

        .btn-primary {
            background: linear-gradient(135deg, #16a34a 0%, #fb923c 100%);
            box-shadow: 0 10px 20px -5px rgba(22, 163, 74, 0.4);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-primary:hover {
            transform: translateY(-3px) scale(1.01);
            box-shadow: 0 15px 25px -5px rgba(22, 163, 74, 0.5);
        }

        .section-title {
            font-size: 0.8rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            color: #166534;
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 2rem 0 1rem 0;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, #dcfce7, transparent);
        }

        .summer-badge {
            background: linear-gradient(to right, #fef3c7, #ffedd5);
            color: #92400e;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
        }
    </style>
</head>
<body class="py-12 px-4">

    <div class="sun-decoration"></div>

    <!-- Màn hình tải dữ liệu -->
    <div id="loadingScreen" class="hidden fixed inset-0 bg-white/60 backdrop-blur-md z-[100] flex items-center justify-center">
        <div class="text-center">
            <div class="relative w-20 h-20 mx-auto">
                <div class="absolute inset-0 border-4 border-orange-100 rounded-full"></div>
                <div class="absolute inset-0 border-4 border-t-orange-500 rounded-full animate-spin"></div>
                <div class="absolute inset-0 flex items-center justify-center text-orange-600">
                    <i class="fa-solid fa-sun text-2xl animate-pulse"></i>
                </div>
            </div>
            <p class="mt-4 text-orange-900 font-bold tracking-tight">Đang xử lý hồ sơ...</p>
        </div>
    </div>

    <div class="max-w-2xl mx-auto">
        <div class="form-card overflow-hidden">
            <!-- Tiêu đề trang -->
            <div class="summer-header p-10 text-center text-white">
                <div class="flex justify-center gap-2 mb-4">
                    <span class="summer-badge">Năng động</span>
                    <span class="summer-badge">Chuyên nghiệp</span>
                </div>
                <h1 class="text-4xl font-black tracking-tighter mb-1 uppercase">Sen Việt Group</h1>
                <p class="text-white/90 text-sm font-medium tracking-wide">PHẦN MỀM ĐĂNG KÝ NHÂN SỰ MÙA HÈ</p>
            </div>

            <div class="p-6 md:p-10">
                <!-- Khu vực Quét mã QR -->
                <div class="bg-orange-50/50 rounded-[2rem] p-6 mb-10 border border-orange-100/50 shadow-inner">
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-orange-500 shadow-sm border border-orange-100">
                                <i class="fa-solid fa-id-card-clip text-2xl"></i>
                            </div>
                            <div>
                                <h2 class="text-base font-extrabold text-gray-800 uppercase leading-none">Quét mã CCCD</h2>
                                <p class="text-xs text-orange-600 font-semibold mt-1">Nhanh chóng & Chính xác</p>
                            </div>
                        </div>
                        <div class="flex gap-3 w-full sm:w-auto">
                            <label for="qr-input-file" class="flex-1 sm:flex-none cursor-pointer bg-white text-gray-700 border border-gray-200 px-5 py-3 rounded-2xl hover:bg-orange-50 transition text-sm flex items-center justify-center font-bold shadow-sm active:scale-95 transform">
                                <i class="fa-solid fa-image-portrait mr-2 text-orange-500"></i> Chọn ảnh
                            </label>
                            <input type="file" id="qr-input-file" accept="image/*" class="hidden">
                            
                            <button id="toggleScanner" class="flex-1 sm:flex-none bg-gray-900 text-white px-5 py-3 rounded-2xl hover:bg-black transition text-sm flex items-center justify-center font-bold shadow-xl active:scale-95 transform">
                                <i class="fa-solid fa-camera mr-2 text-orange-400"></i> Quét trực tiếp
                            </button>
                        </div>
                    </div>

                    <div id="scanner-wrapper" class="hidden space-y-4">
                        <div id="reader" class="scanner-container shadow-2xl"></div>
                        <div class="bg-white/60 p-4 rounded-2xl border border-orange-100 text-[11px] text-gray-600 flex gap-3 items-start shadow-sm">
                            <i class="fa-solid fa-circle-info text-orange-500 mt-0.5 text-base"></i>
                            <p><b>Mẹo nhỏ:</b> Căn chỉnh mã QR vào giữa khung hình. Ứng dụng sẽ tự động trích xuất thông tin cá nhân và điền vào biểu mẫu bên dưới.</p>
                        </div>
                    </div>

                    <div id="scan-status" class="hidden text-center p-4 bg-white text-orange-600 text-xs font-black rounded-2xl border-2 border-orange-200 animate-pulse uppercase tracking-widest">
                        <i class="fa-solid fa-wand-magic-sparkles mr-2"></i> Đang trích xuất dữ liệu...
                    </div>
                </div>

                <!-- Biểu mẫu đăng ký -->
                <form id="registrationForm" class="space-y-8">
                    <div class="section-title">
                        <i class="fa-solid fa-briefcase text-orange-500"></i> LỊCH TRÌNH ĐIỀU ĐỘNG
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Ngày đăng ký</label>
                            <input type="date" id="ngayDangKy" name="ngayDangKy" class="styled-input block w-full p-4" required>
                            <i class="fa-solid fa-calendar-check input-icon"></i>
                        </div>

                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Công ty tiếp nhận</label>
                            <select id="tenCongTy" name="tenCongTy" class="styled-input block w-full p-4 cursor-pointer" required>
                                <option value="">-- Chọn công ty --</option>
                                <option value="ADTECK CT">ADTECK CT</option>
                                <option value="GOERTEK NAM SƠN">GOERTEK NAM SƠN</option>
                                <option value="GOERTEK QUẾ VÕ">GOERTEK QUẾ VÕ</option>
                                <option value="NEWWING">NEWWING</option>
                                <option value="FUKANG">FUKANG</option>
                                <option value="FUYU">FUYU</option>
                                <option value="FULIAN">FULIAN</option>
                                <option value="FINE MS TV">FINE MS TV</option>
                                <option value="HS TV">HS TV</option>
                                <option value="AAC CT">AAC CT</option>
                                <option value="AAC TV">AAC TV</option>
                                <option value="FUSHAN CT">FUSHAN CT</option>
                                <option value="ASKEY">ASKEY</option>
                                <option value="VMEIJIA">VMEIJIA</option>
                                <option value="SHUN YUN">SHUN YUN</option>
                                <option value="LUXSHARE QC1">LUXSHARE QC1</option>
                                <option value="LUXSHARE QC 2&3">LUXSHARE QC 2&3</option>
                                <option value="LENS">LENS</option>
                                <option value="AUSTONE TV">AUSTONE TV</option>
                                <option value="YUZHAN TV">YUZHAN TV</option>
                                <option value="YUZHAN CT">YUZHAN CT</option>
                                <option value="HS CHÍNH THỨC">HS CHÍNH THỨC</option>
                            </select>
                            <i class="fa-solid fa-city input-icon"></i>
                        </div>

                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Nhà cung ứng</label>
                            <select id="nhaCungUng" name="nhaCungUng" class="styled-input block w-full p-4 cursor-pointer" required>
                                <option value="">-- Chọn nhà cung ứng --</option>
                                <option value="HÙNG">HÙNG</option>
                                <option value="NGUYỆT">NGUYỆT</option>
                                <option value="THANH">THANH</option>
                                <option value="KHIÊM">KHIÊM</option>
                                <option value="ĐẠT">ĐẠT</option>
                                <option value="TRƯỜNG">TRƯỜNG</option>
                                <option value="THÚY">THÚY</option>
                                <option value="TỚI">TỚI</option>
                                <option value="NGHĨA">NGHĨA</option>
                                <option value="GIANG">GIANG</option>
                                <option value="SEN VIỆT">SEN VIỆT</option>
                                <option value="SEN VIỆT AI">SEN VIỆT AI</option>
                            </select>
                            <i class="fa-solid fa-handshake-angle input-icon"></i>
                        </div>

                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Số điện thoại liên hệ</label>
                            <input type="tel" id="soDienThoai" name="soDienThoai" placeholder="Nhập số điện thoại" class="styled-input block w-full p-4" required>
                            <i class="fa-solid fa-mobile-screen input-icon"></i>
                        </div>
                    </div>

                    <div class="section-title">
                        <i class="fa-solid fa-user-check text-orange-500"></i> HỒ SƠ NHÂN VIÊN
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="input-group md:col-span-2">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Họ tên (In hoa)</label>
                            <input type="text" id="hoTen" name="hoTen" class="styled-input block w-full font-black text-green-800 p-4 uppercase" placeholder="HỌ VÀ TÊN" required>
                            <i class="fa-solid fa-signature input-icon"></i>
                        </div>

                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Số CCCD</label>
                            <input type="text" id="soCCCD" name="soCCCD" class="styled-input block w-full p-4 font-mono" placeholder="12 chữ số" required>
                            <i class="fa-solid fa-id-card input-icon"></i>
                        </div>

                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Ngày sinh</label>
                            <input type="date" id="ngaySinh" name="ngaySinh" class="styled-input block w-full p-4">
                            <i class="fa-solid fa-cake-candles input-icon"></i>
                        </div>

                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Giới tính</label>
                            <select id="gioiTinh" name="gioiTinh" class="styled-input block w-full p-4">
                                <option value="">-- Chọn --</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                            </select>
                            <i class="fa-solid fa-venus-mars input-icon"></i>
                        </div>

                        <div class="input-group">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Ngày cấp thẻ</label>
                            <input type="date" id="ngayCap" name="ngayCap" class="styled-input block w-full p-4">
                            <i class="fa-solid fa-calendar-day input-icon"></i>
                        </div>

                        <div class="input-group md:col-span-2">
                            <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Nơi cấp</label>
                            <input type="text" id="noiCap" name="noiCap" value="Cục Cảnh sát QLHC về TTXH" class="styled-input block w-full p-4" placeholder="Cơ quan cấp thẻ">
                            <i class="fa-solid fa-building-shield input-icon"></i>
                        </div>
                    </div>

                    <div class="input-group">
                        <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Địa chỉ thường trú</label>
                        <textarea id="diaChi" name="diaChi" rows="2" class="styled-input block w-full p-4 pt-4" placeholder="Địa chỉ chi tiết trên CCCD"></textarea>
                        <i class="fa-solid fa-map-location input-icon" style="top: 25px; transform: none;"></i>
                    </div>

                    <div class="input-group">
                        <label class="block text-[11px] font-bold text-gray-400 uppercase mb-2 ml-1">Ghi chú</label>
                        <input type="text" id="ghiChu" name="ghiChu" placeholder="Thông tin bổ sung..." class="styled-input block w-full p-4">
                        <i class="fa-solid fa-note-sticky input-icon"></i>
                    </div>

                    <div class="pt-8">
                        <button type="submit" id="submitBtn" class="btn-primary w-full text-white font-black py-5 rounded-[1.5rem] flex items-center justify-center text-lg active:scale-95 transform tracking-tight">
                            <i class="fa-solid fa-paper-plane mr-3 text-xl"></i> HOÀN TẤT ĐĂNG KÝ
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Chân trang -->
        <div class="text-center mt-12 space-y-3">
            <div class="flex justify-center gap-6 text-orange-400/30 text-2xl">
                <i class="fa-solid fa-umbrella-beach"></i>
                <i class="fa-solid fa-sun fa-spin-slow" style="animation: spin 8s linear infinite;"></i>
                <i class="fa-solid fa-leaf"></i>
            </div>
            <p class="text-gray-400 text-[10px] font-bold tracking-[0.2em] uppercase">Powered by Sen Việt HR System • 2026</p>
        </div>
    </div>

    <!-- Thông báo thành công -->
    <div id="successModal" class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-white p-10 rounded-[3rem] max-w-sm w-full text-center shadow-2xl border border-orange-100">
            <div class="w-24 h-24 bg-orange-50 rounded-full flex items-center justify-center mx-auto mb-6 border-8 border-orange-100/50">
                <i class="fa-solid fa-check text-5xl text-orange-500"></i>
            </div>
            <h3 class="text-3xl font-black text-gray-800 mb-2 tracking-tighter uppercase">Thành công!</h3>
            <p class="text-gray-500 mb-8 font-medium leading-relaxed">Chào mừng <span id="savedName" class="text-green-600 font-bold"></span> gia nhập Sen Việt Group!</p>
            <button onclick="closeModal()" class="w-full bg-gray-900 text-white py-5 rounded-[1.5rem] font-bold hover:bg-black transition shadow-lg active:scale-95 transform">TIẾP TỤC ĐĂNG KÝ</button>
        </div>
    </div>

    <script>
        document.getElementById('ngayDangKy').valueAsDate = new Date();

        const html5QrCode = new Html5Qrcode("reader");
        const fileInput = document.getElementById('qr-input-file');
        const scannerWrapper = document.getElementById('scanner-wrapper');
        const toggleBtn = document.getElementById('toggleScanner');
        const scanStatus = document.getElementById('scan-status');
        const loadingScreen = document.getElementById('loadingScreen');
        
        let isScannerOpen = false;

        fileInput.addEventListener('change', e => {
            if (e.target.files.length === 0) return;
            scanStatus.classList.remove('hidden');
            html5QrCode.scanFile(e.target.files[0], true)
                .then(decodedText => {
                    processQRData(decodedText);
                    scanStatus.classList.add('hidden');
                    fileInput.value = "";
                })
                .catch(err => {
                    scanStatus.classList.add('hidden');
                    alert("❌ Lỗi: Hình ảnh không chứa mã QR hợp lệ hoặc quá mờ. Vui lòng thử lại!");
                });
        });

        toggleBtn.addEventListener('click', () => {
            if (!isScannerOpen) {
                scannerWrapper.classList.remove('hidden');
                toggleBtn.innerHTML = '<i class="fa-solid fa-stop-circle mr-2"></i> Tắt Camera';
                toggleBtn.classList.replace('bg-gray-900', 'bg-red-500');
                
                html5QrCode.start(
                    { facingMode: "environment" }, 
                    { fps: 20, qrbox: { width: 250, height: 250 } }, 
                    (text) => {
                        processQRData(text);
                        stopScanner();
                    }
                ).catch(err => {
                    alert("Lỗi camera: Vui lòng cấp quyền truy cập camera!");
                    stopScanner();
                });
                isScannerOpen = true;
            } else {
                stopScanner();
            }
        });

        function stopScanner() {
            if (isScannerOpen) {
                html5QrCode.stop().then(() => {
                    scannerWrapper.classList.add('hidden');
                    toggleBtn.innerHTML = '<i class="fa-solid fa-camera mr-2 text-orange-400"></i> Quét trực tiếp';
                    toggleBtn.classList.replace('bg-red-500', 'bg-gray-900');
                    isScannerOpen = false;
                });
            }
        }

        function formatToDateInput(str) {
            if (str && str.length === 8) {
                return `${str.substring(4,8)}-${str.substring(2,4)}-${str.substring(0,2)}`;
            }
            return "";
        }

        function processQRData(data) {
            const parts = data.split('|');
            if (parts.length >= 6) {
                const cccdNumber = parts[0] || '';
                document.getElementById('soCCCD').value = cccdNumber;
                document.getElementById('hoTen').value = (parts[2] || '').toUpperCase();
                
                if (parts[3]) document.getElementById('ngaySinh').value = formatToDateInput(parts[3]);

                const gt = parts[4] || '';
                if (gt.includes('Nam')) document.getElementById('gioiTinh').value = 'Nam';
                else if (gt.includes('Nữ')) document.getElementById('gioiTinh').value = 'Nữ';
                
                document.getElementById('diaChi').value = parts[5] || '';
                
                if (parts[6]) document.getElementById('ngayCap').value = formatToDateInput(parts[6]);
                
                // Tự động cập nhật nơi cấp khi quét CCCD 12 số
                if (cccdNumber && cccdNumber.length === 12) {
                    document.getElementById('noiCap').value = "Cục Cảnh sát QLHC về TTXH";
                }

                const fields = ['soCCCD', 'hoTen', 'ngaySinh', 'gioiTinh', 'diaChi', 'ngayCap', 'noiCap'];
                fields.forEach(id => {
                    const el = document.getElementById(id);
                    el.classList.add('bg-orange-50');
                    setTimeout(() => el.classList.remove('bg-orange-50'), 1500);
                });
            } else {
                alert("Định dạng QR không phải CCCD hợp lệ.");
            }
        }

        document.getElementById('registrationForm').onsubmit = async function(e) {
            e.preventDefault();
            const hoTen = document.getElementById('hoTen').value;
            const fmt = (d) => { 
                if(!d) return ""; 
                const p = d.split('-'); 
                return `${p[2]}/${p[1]}/${p[0]}`; 
            };

            const dataToSend = {
                ngay_dang_ky: fmt(document.getElementById('ngayDangKy').value),
                ten_cong_ty: document.getElementById('tenCongTy').value,
                nha_cung_ung: document.getElementById('nhaCungUng').value,
                ho_ten: hoTen,
                so_cccd: document.getElementById('soCCCD').value,
                ngay_sinh: fmt(document.getElementById('ngaySinh').value),
                gioi_tinh: document.getElementById('gioiTinh').value,
                ngay_cap: fmt(document.getElementById('ngayCap').value),
                noi_cap: document.getElementById('noiCap').value,
                dia_chi_thuong_tru: document.getElementById('diaChi').value,
                so_dien_thoai: document.getElementById('soDienThoai').value,
                ghi_chu: document.getElementById('ghiChu').value
            };

            loadingScreen.classList.remove('hidden');

            try {
                const response = await fetch('https://senvietgroup.com/webhook-test/51da928e-78c3-45df-80ec-c4bb8f6081e7', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dataToSend)
                });
                
                if (response.ok) {
                    document.getElementById('savedName').innerText = hoTen;
                    document.getElementById('successModal').classList.remove('hidden');
                } else {
                    throw new Error("Lỗi máy chủ.");
                }
            } catch (error) {
                alert("Lỗi kết nối: " + error.message);
            } finally {
                loadingScreen.classList.add('hidden');
            }
        };

        function closeModal() {
            document.getElementById('successModal').classList.add('hidden');
            document.getElementById('registrationForm').reset();
            document.getElementById('ngayDangKy').valueAsDate = new Date();
            // Đặt lại nơi cấp mặc định sau khi reset form
            document.getElementById('noiCap').value = "Cục Cảnh sát QLHC về TTXH";
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</body>
</html>